 #define MLX90614_ADDR  0x5A     // pirometr (domyślny)
-#define ICM20948_ADDR  0x68     // IMU (AD0=GND→0x68, AD0=VCC→0x69)
+#define ICM20948_ADDR  0x68     // IMU (AD0=GND→0x68, AD0=VCC→0x69; auto-probe)
